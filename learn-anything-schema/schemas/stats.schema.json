{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://learn-anything.dev/schemas/stats.json",
  "title": "Session Stats",
  "description": "Schema for srs/stats.json — quiz and review session history",
  "type": "object",
  "required": ["sessions"],
  "properties": {
    "sessions": {
      "type": "array",
      "items": { "$ref": "#/$defs/session" }
    }
  },
  "$defs": {
    "session": {
      "type": "object",
      "required": ["date", "type", "topic"],
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "Session date: YYYY-MM-DD"
        },
        "type": {
          "type": "string",
          "enum": ["quiz", "review"],
          "description": "Session type"
        },
        "topic": {
          "type": "string",
          "description": "Course/topic directory name"
        },
        "module": {
          "type": ["string", "null"],
          "description": "Module directory name (present for quiz sessions)"
        },
        "score": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Number of correct answers"
        },
        "total": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "Total questions in session"
        }
      }
    }
  }
}
