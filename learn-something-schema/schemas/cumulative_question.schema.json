{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://learn-something.dev/schemas/cumulative_question.json",
  "title": "Cumulative Quiz Question",
  "description": "Schema for a single cumulative quiz question (mcq, cloze, or tf)",
  "oneOf": [
    { "$ref": "#/$defs/mcq" },
    { "$ref": "#/$defs/cloze" },
    { "$ref": "#/$defs/tf" }
  ],
  "$defs": {
    "mcq": {
      "type": "object",
      "required": ["id", "type", "question", "source_modules", "options", "answer", "explanation", "difficulty", "tags"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^cum\\.\\d+$",
          "description": "Question ID: cum.N"
        },
        "type": {
          "type": "string",
          "const": "mcq"
        },
        "question": {
          "type": "string",
          "minLength": 1,
          "description": "Question text"
        },
        "source_modules": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 1,
          "description": "Module numbers this question covers"
        },
        "options": {
          "type": "object",
          "minProperties": 4,
          "maxProperties": 4,
          "additionalProperties": { "type": "string" },
          "description": "Answer options with uppercase keys: A, B, C, D"
        },
        "answer": {
          "type": "string",
          "enum": ["A", "B", "C", "D"],
          "description": "Correct answer key"
        },
        "explanation": {
          "type": "string",
          "description": "Why this answer is correct"
        },
        "difficulty": {
          "type": "integer",
          "enum": [1, 2, 3],
          "description": "1=recall, 2=comprehension, 3=application"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Content tags"
        }
      }
    },
    "cloze": {
      "type": "object",
      "required": ["id", "type", "question", "source_modules", "answer", "explanation", "difficulty", "tags"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^cum\\.\\d+$",
          "description": "Question ID: cum.N"
        },
        "type": {
          "type": "string",
          "const": "cloze"
        },
        "question": {
          "type": "string",
          "description": "Sentence with {blank} for term to fill in"
        },
        "source_modules": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 1,
          "description": "Module numbers this question covers"
        },
        "answer": {
          "type": "string",
          "description": "The term that fills the blank"
        },
        "explanation": {
          "type": "string",
          "description": "Why this term is correct"
        },
        "difficulty": {
          "type": "integer",
          "enum": [1, 2, 3],
          "description": "1=recall, 2=comprehension, 3=application"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Content tags"
        }
      }
    },
    "tf": {
      "type": "object",
      "required": ["id", "type", "statement", "source_modules", "answer", "explanation", "difficulty", "tags"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^cum\\.\\d+$",
          "description": "Question ID: cum.N"
        },
        "type": {
          "type": "string",
          "const": "tf"
        },
        "statement": {
          "type": "string",
          "description": "Statement to evaluate as true or false"
        },
        "source_modules": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 1,
          "description": "Module numbers this question covers"
        },
        "answer": {
          "type": "boolean",
          "description": "True if statement is correct, False if incorrect"
        },
        "explanation": {
          "type": "string",
          "description": "Why true/false, referencing concepts from source modules"
        },
        "difficulty": {
          "type": "integer",
          "enum": [1, 2, 3],
          "description": "1=recall, 2=comprehension, 3=application"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Content tags"
        }
      }
    }
  }
}
