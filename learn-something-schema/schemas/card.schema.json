{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://learn-something.dev/schemas/card.json",
  "title": "SRS Card",
  "description": "Schema for a single spaced repetition card",
  "type": "object",
  "required": ["id", "questionId", "moduleId", "courseId", "question", "answer", "easeFactor", "interval", "repetitions", "nextReviewDate"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Card ID: {courseId}-{moduleId}-{questionId}"
    },
    "questionId": {
      "type": "string",
      "description": "Original quiz question ID, e.g. '1.2'"
    },
    "moduleId": {
      "type": "string",
      "description": "Module directory name, e.g. '01-intro'"
    },
    "courseId": {
      "type": "string",
      "description": "Course directory name, e.g. 'python-basics'"
    },
    "question": {
      "type": "string",
      "description": "Question text"
    },
    "answer": {
      "type": "string",
      "description": "Format: '{key}. {option text}', e.g. 'a. Python'"
    },
    "explanation": {
      "type": "string",
      "description": "Why this answer is correct"
    },
    "easeFactor": {
      "type": "number",
      "minimum": 1.3,
      "default": 2.5,
      "description": "SM-2 ease factor. Starts at 2.5, min 1.3"
    },
    "interval": {
      "type": "number",
      "minimum": 0,
      "description": "Days until next review"
    },
    "repetitions": {
      "type": "integer",
      "minimum": 0,
      "description": "Count of consecutive correct reviews"
    },
    "nextReviewDate": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime when card is next due"
    },
    "lastReviewed": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 datetime of last review, or null if never reviewed"
    },
    "isStarred": {
      "type": "boolean",
      "default": false,
      "description": "Whether user has starred this card"
    }
  }
}
